---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import RequestRoutingVisual from '../components/RequestRoutingVisual.astro';
import CompoundingSection from '../components/CompoundingSection.astro';
---

<Layout
  title="Inform Growth - AI-Native Revenue Operations for B2B"
  description="Your revenue team is using AI in silos. We deploy a unified AI layer into your revenue stack - shared context, compounding learnings, and data that improves itself. One team. Zero handoffs."
>
  <!-- SECTION 1: HERO -->
  <section class="hero-section geo-grid">
    <div class="container">
      <div class="hero-content">
        <h1>Governed AI for <span class="highlight-word">Revenue Teams.</span></h1>
        <p class="hero-subtitle">
          One AI layer across your entire revenue stack. Shared context. Compounding learnings. No hallucinations. No chaos.
        </p>
        <div class="hero-ctas">
          <a href="/contact" class="btn btn-primary btn-large">Book a Meeting</a>
          <a href="/services" class="btn btn-secondary btn-large">See How It Works</a>
        </div>
        <div class="hero-trust-row">
          <span class="trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Your credentials stay local
          </span>
          <span class="trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            Read-only by default
          </span>
          <span class="trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Live in 2 weeks
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: TESTIMONIAL CAROUSEL -->
  <TestimonialCarousel />

  <!-- SECTION 3: PROOF STRIP -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-stats">
        <div class="proof-stat">
          <span class="stat-number">32%</span>
          <span class="stat-label">Revenue Increase</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">40%</span>
          <span class="stat-label">Churn Reduction</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">75%</span>
          <span class="stat-label">CRM Cost Reduction</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">27%</span>
          <span class="stat-label">Marketing ROI Lift</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">40%</span>
          <span class="stat-label">Data Cost Savings</span>
        </div>
      </div>
      <div class="logo-strip" role="list" aria-label="Clients">
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/chiefofstaffnetwork_dark_logo.png"
            alt="Chief of Staff Network"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/howdysales_logo.png"
            alt="Howdy Sales"
            loading="lazy"
            decoding="async"
            style="max-height: 100px;"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/sylva_logo.svg"
            alt="Sylva"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/revenue_accelerator_logo_new-removebg-preview.png"
            alt="Revenue Accelerator"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/WTA-Logo-High-Vis-removebg-preview.png"
            alt="WTA"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>


  <!-- SECTION: REQUEST ROUTING VISUAL -->
  <section style="max-width:1200px;margin:4rem auto;padding:0 2rem;">
    <RequestRoutingVisual />
  </section>

  <!-- SECTION: COMPOUNDING -->
  <CompoundingSection />



  <!-- SECTION 9: FAQ -->
  <section class="faq-section section">
    <div class="container">
      <h2 class="text-center fade-up">Before You Ask</h2>
      <div class="faq-grid fade-up">
        <details class="faq-item">
          <summary class="faq-question">What do you mean by "AI layer"?</summary>
          <div class="faq-answer">
            <p>Right now, your sales team uses ChatGPT. Marketing has Jasper or Copy.ai. CS has their own tools. Nobody shares context, learnings get lost, and your best operator's knowledge walks out the door when they leave.</p>
            <p>We deploy a governed AI infrastructure that sits across your entire revenue stack. One shared brain. When an operator closes a deal, the system learns. When marketing finds messaging that converts, everyone benefits. Context compounds instead of resetting.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">We already have a RevOps person. Why do we need you?</summary>
          <div class="faq-answer">
            <p>Your RevOps team is probably overloaded maintaining Salesforce, HubSpot, and Outreach. They don't have time to re-architect your systems for AI, build unified data layers, or experiment with new tooling.</p>
            <p>We're not here to replace them - we're here to handle the infrastructure work they don't have bandwidth for. They stay strategic. We handle the data plumbing and AI deployment.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What's the $100K guarantee actually mean?</summary>
          <div class="faq-answer">
            <p>We run our Deep-Scan diagnostic against your CRM, and if we don't find at least $100K in recoverable pipeline - orphaned deals, zombie opportunities, reactivation candidates - you don't pay.</p>
            <p>We're confident because the math is on our side. The average mid-market B2B company has 15-25% of revenue leaking due to data issues. We've never missed.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Is my data safe?</summary>
          <div class="faq-answer">
            <p>Your credentials stay on your infrastructure, not ours. The AI layer we deploy is read-only by default - it can query your systems to answer questions but cannot modify data unless you explicitly approve it.</p>
            <p>Every integration goes through automated and human QA review before touching production. We're building data infrastructure, not a liability.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How is this different from hiring a RevOps consultant?</summary>
          <div class="faq-answer">
            <p>Most consultants diagnose problems and hand you a deck. Then you hire someone else to implement. Context gets lost. Timelines slip. The deck becomes shelf-ware.</p>
            <p>We scope, build, and operate inside your stack. One team from diagnosis to delivery. The person who finds the problem fixes it. No handoffs, no translation layers, no 6-month discovery phases.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How fast can you start?</summary>
          <div class="faq-answer">
            <p>Deep-Scan starts within a week. Full builds kick off within 2 weeks. We bring our own AI tooling, so we don't waste months evaluating vendors or building from scratch.</p>
            <p>If you need to show progress to your board in 90 days, that's exactly the kind of timeline we're built for.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- SECTION 10: FINAL CTA -->
  <section class="section bottom-cta geo-grid">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to explore?</h2>
        <a href="/contact" class="btn btn-primary btn-large">Book a Meeting</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* SECTION 1: HERO */
  .hero-section {
    background-color: var(--color-bg-base);
    padding: var(--space-2xl) 0 var(--space-lg);
    position: relative;
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  .hero-section h1 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--heading-color);
    line-height: 1.15;
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 750px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-ctas {
      flex-direction: row;
      justify-content: center;
    }
  }

  .hero-trust-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  @media (min-width: 480px) {
    .hero-trust-row {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      column-gap: var(--space-6);
      row-gap: var(--space-2);
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    opacity: 0.82;
  }

  .trust-item svg {
    flex-shrink: 0;
  }

  /* Highlight and rotating word animation */
  .highlight-word {
    color: var(--sky-blue);
  }

  .rotating-word-wrap {
    display: inline-block;
  }

  .rotating-word {
    display: inline-block;
    color: var(--sky-blue);
    animation: fadeInUp 0.5s ease;
  }

  .hero-section h1 {
    text-align: center;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* SECTION 2: PROOF STRIP */
  .proof-strip {
    background-color: var(--color-bg-surface);
    padding: var(--space-8) 0;
  }


  .proof-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .proof-stats {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .proof-stat {
    text-align: center;
    background-color: var(--color-bg-raised);
    padding: var(--space-5) var(--space-4);
    border-radius: var(--card-radius);
    border: 1px solid var(--color-border);
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }


  .proof-clients-meta {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    margin-top: var(--space-6);
  }

  /* Logo strip */
  .logo-strip {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-lg);
    margin-top: var(--space-6);
  }

  .logo-lockup--dark img {
    opacity: 0.7;
    filter: brightness(0);
    max-height: 72px;
    width: auto;
    transition: opacity var(--transition-fast);
  }

  .logo-lockup--dark:hover img {
    opacity: 1;
  }

  /* PROCESS SECTION */
  /* SECTION 3: THREE PILLARS */
  .pillars-section {
    background-color: var(--page-bg);
  }

  .pillars-section h2 {
    max-width: 900px;
    margin: 0 auto var(--space-2xl);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 900px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar-card {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-card);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    transition: box-shadow var(--transition-base);
  }

  .pillar-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .pillar-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-subtle);
  }

  .pillar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: rgba(200, 240, 74, 0.1);
    border-radius: 10px;
    color: var(--sky-blue);
    flex-shrink: 0;
  }

  .pillar-icon svg {
    display: block;
  }

  .pillar-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--heading-color);
    margin: 0;
  }

  .pillar-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  .pillar-problem p,
  .pillar-solution p,
  .pillar-result p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.7;
    margin: 0;
  }

  /* SECTION 4: PROBLEM */
  .problem-section {
    background-color: var(--page-bg);
  }

  .pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 1100px;
    margin: 0 auto var(--space-xl);
  }

  @media (min-width: 768px) {
    .pain-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pain-item {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    padding: var(--space-6);
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    border-left: 4px solid var(--warning-red);
    font-style: italic;
    box-shadow: var(--shadow-sm);
  }

  .stakes-callout {
    max-width: 900px;
    margin: 0 auto var(--space-8);
    padding: var(--space-6);
    background-color: rgba(220, 38, 38, 0.08);
    border-radius: var(--card-radius);
    border: 2px solid var(--warning-red);
  }

  .stakes-callout p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--warning-red);
    text-align: center;
    margin: 0;
    font-weight: 600;
  }


  /* SECTION 5: DEEP-SCAN FEATURE */
  .deepscan-section {
    background-color: var(--navy);
    position: relative;
  }

  .deepscan-section h2 {
    color: #FFFFFF;
  }

  .deepscan-intro {
    max-width: 900px;
    margin: 0 auto var(--space-xl);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
  }

  /* Light variant */
  .deepscan-section--light {
    background-color: var(--section-light-bg, var(--page-bg));
  }

  .deepscan-section--light h2 {
    color: var(--heading-color);
  }

  .deepscan-section--light .deepscan-intro {
    color: var(--muted-text);
  }

  .deepscan-section--light .deepscan-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-card);
  }

  .deepscan-section--light .deepscan-card h4 {
    color: var(--heading-color);
  }

  .deepscan-section--light .deepscan-card p {
    color: var(--muted-text);
  }

  .deepscan-section--light .guarantee-text {
    color: var(--emerald);
  }

  .deepscan-section--light .guarantee-sub {
    color: var(--slate);
  }

  .deepscan-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .deepscan-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .deepscan-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .deepscan-card {
    background-color: var(--navy-light);
    border-radius: var(--card-radius);
    padding: var(--space-6);
    transition: transform var(--transition-fast);
    display: flex;
    flex-direction: column;
  }

  .deepscan-card:hover {
    transform: translateY(-4px);
  }

  .deepscan-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    color: #C8F04A;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: rgba(200, 240, 74, 0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: 4px;
    margin-top: auto;
    padding-top: var(--space-4);
    align-self: flex-start;
  }

  .deepscan-card h4 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: #FFFFFF;
    margin-bottom: var(--space-3);
  }

  .deepscan-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin: 0;
  }

  .deepscan-guarantee {
    text-align: center;
  }

  .guarantee-text {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--emerald);
    margin-bottom: var(--space-8);
  }

  .guarantee-sub {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-6);
    opacity: 0.8;
  }

  /* SECTION 6: CASE STUDIES */
  .casestudies-section h2 {
    margin-bottom: var(--space-2xl);
  }

  .case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .case-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .case-card {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-card);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: box-shadow var(--transition-base), transform var(--transition-fast);
  }

  .case-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .case-logo {
    margin-bottom: var(--space-4);
  }

  .case-logo .logo-lockup {
    height: 36px;
  }


  .case-context {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--slate);
    opacity: 0.7;
    margin: var(--space-2) 0 var(--space-4);
  }

  .case-pillar {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .case-card h4 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
    margin: 0;
  }

  .case-metric {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--emerald);
  }

  .case-details {
    flex: 1;
  }

  .case-details p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .case-details strong {
    color: var(--text-color);
    font-weight: 600;
  }

  .case-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-blue);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .case-link:hover {
    color: var(--sky-blue-light);
  }

  /* SECTION 6.5: TESTIMONIAL STRIP */
  .testimonial-strip {
    background-color: var(--navy);
    padding: var(--space-section-mobile) 0;
  }

  @media (min-width: 768px) {
    .testimonial-strip {
      padding: var(--space-section) 0;
    }
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .testimonial-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .testimonial-card {
    border-left: 3px solid var(--sky-blue);
    padding-left: var(--space-6);
  }

  .testimonial-quote {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: #FFFFFF;
    line-height: 1.55;
    font-style: italic;
    margin-bottom: var(--space-4);
  }

  .testimonial-attribution {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial-name {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #C8F04A;
  }

  .testimonial-role {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.65);
  }

