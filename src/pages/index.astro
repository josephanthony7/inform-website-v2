---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import RequestRoutingVisual from '../components/RequestRoutingVisual.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
---

<Layout
  title="Inform Growth - Sales. Data. Systems. Fixed Together."
  description="We build revenue engines for mid-market B2B. Sales process design, data engineering, and RevTech implementation - by one team, with zero handoffs. $100K+ in leaked pipeline found or you don't pay."
>
  <!-- SECTION 1: HERO -->
  <section class="hero-section geo-grid">
    <div class="container">
      <div class="hero-content">
        <h1><span class="highlight-word">Revenue</span><br/>Operations, Data, and Systems<br/><span class="rotating-word-wrap"><span class="rotating-word">Built to Compound</span></span></h1>
        <p class="hero-subtitle">
          We build the AI layer that connects your data, systems, and people - so your entire revenue engine runs from one source of truth.
        </p>
        <div class="hero-ctas">
          <a href="/contact" class="btn btn-primary btn-large">Connect with us today</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: TESTIMONIAL CAROUSEL -->
  <TestimonialCarousel />

  <!-- SECTION 3: PROOF STRIP -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-stats">
        <div class="proof-stat">
          <span class="stat-number">32%</span>
          <span class="stat-label">Revenue Increase</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">40%</span>
          <span class="stat-label">Churn Reduction</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">75%</span>
          <span class="stat-label">CRM Cost Reduction</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">27%</span>
          <span class="stat-label">Marketing ROI Lift</span>
        </div>
        <div class="proof-stat">
          <span class="stat-number">40%</span>
          <span class="stat-label">Data Cost Savings</span>
        </div>
      </div>
      <div class="logo-strip" role="list" aria-label="Clients">
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/chiefofstaffnetwork_dark_logo.png"
            alt="Chief of Staff Network"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/howdysales_logo.png"
            alt="Howdy Sales"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/sylva_logo.svg"
            alt="Sylva"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/revenue_accelerator_logo_new-removebg-preview.png"
            alt="Revenue Accelerator"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="logo-lockup logo-lockup--dark" role="listitem">
          <img
            src="/clients/WTA-Logo-High-Vis-removebg-preview.png"
            alt="WTA"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <p class="proof-clients-meta">Real results from real engagements</p>
    </div>
  </section>


  <!-- SECTION: REQUEST ROUTING VISUAL -->
  <section style="max-width:900px;margin:4rem auto;padding:0 1.5rem;">
    <RequestRoutingVisual />
  </section>

  <!-- SECTION: PROCESS FLOW -->
  <ProcessFlow />



  <!-- SECTION 9: FAQ -->
  <section class="faq-section section">
    <div class="container">
      <h2 class="text-center fade-up">Before You Ask</h2>
      <div class="faq-grid fade-up">
        <details class="faq-item">
          <summary class="faq-question">How is this different from hiring a HubSpot consultant?</summary>
          <div class="faq-answer">
            <p>Most HubSpot consultants focus on making HubSpot work. We focus on making your entire revenue engine work - which sometimes means fixing HubSpot, sometimes means fixing your sales process, and sometimes means integrating systems that have nothing to do with HubSpot.</p>
            <p>We also have someone on the team who's actually closed enterprise deals, so we know what it feels like when the tools don't work.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">We already have a RevOps person. Why do we need you?</summary>
          <div class="faq-answer">
            <p>We're not here to replace your RevOps person - we're here to extend their capacity. Most internal RevOps leaders are drowning in tickets and don't have the bandwidth to do the strategic work they know needs to happen.</p>
            <p>We come in as allies, not competitors. We handle the heavy lifting, document everything, and hand it back in a state they can maintain.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What's the $100K guarantee actually mean?</summary>
          <div class="faq-answer">
            <p>We run our Deep-Scan diagnostic against your CRM, and if we don't find at least $100K in recoverable pipeline - orphaned deals, zombie opportunities, reactivation candidates - you don't pay the $1,500 fee.</p>
            <p>We're confident because the math is on our side. The average mid-market B2B company has 15-25% of revenue leaking due to data issues.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Can you really do sales process AND systems work?</summary>
          <div class="faq-answer">
            <p>That's the whole point. Jaron has spent years building revenue systems - 400K+ records migrated, 75% CRM cost reductions. Joseph has spent years actually selling - $900K ARR deals at Checkout.com, $2M in new business.</p>
            <p>When we build a system, it gets stress-tested by someone who's had to sell with broken tools. When we design a sales process, it gets implemented by someone who knows how to make CRMs work.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How fast can you start?</summary>
          <div class="faq-answer">
            <p>We can typically start a Deep-Scan within a week of signing. For full Pipeline Re-Architecture projects, we usually kick off within 2 weeks.</p>
            <p>We're a small, focused team - not a big consultancy with 6-month discovery phases. If you need to show progress to your board in 90 days, that's exactly the kind of timeline we're built for.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- SECTION 10: FINAL CTA -->
  <section class="final-cta-section section geo-grid">
    <div class="container">
      <div class="final-cta-content fade-up">
        <h2>Ready to fix your revenue engine?</h2>
        <a href="/contact" class="btn btn-primary btn-large">Book a Meeting</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* SECTION 1: HERO */
  .hero-section {
    background-color: var(--navy);
    padding: var(--space-section) 0;
    position: relative;
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-section h1 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: var(--space-8);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--off-white);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-ctas {
      flex-direction: row;
      justify-content: center;
    }
  }

  .hero-trust-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  @media (min-width: 480px) {
    .hero-trust-row {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      column-gap: var(--space-6);
      row-gap: var(--space-2);
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--off-white);
    opacity: 0.82;
  }

  .trust-item svg {
    flex-shrink: 0;
  }

  /* Highlight and rotating word animation */
  .highlight-word {
    color: var(--sky-blue);
  }

  .rotating-word-wrap {
    display: inline-block;
  }

  .rotating-word {
    display: inline-block;
    color: var(--sky-blue);
    animation: fadeInUp 0.5s ease;
  }

  .hero-section h1 {
    text-align: center;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* SECTION 2: PROOF STRIP */
  .proof-strip {
    background-color: var(--pale-blue);
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border-subtle);
  }


  .proof-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .proof-stats {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .proof-stat {
    text-align: center;
    background-color: var(--white);
    padding: var(--space-5) var(--space-4);
    border-radius: var(--card-radius);
    border: 1px solid var(--border-subtle);
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--navy);
    margin-bottom: var(--space-1);
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--slate);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }


  .proof-clients-meta {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--slate);
    opacity: 0.7;
    margin-top: var(--space-6);
  }

  /* PROCESS SECTION */
  /* SECTION 3: THREE PILLARS */
  .pillars-section {
    background-color: var(--page-bg);
  }

  .pillars-section h2 {
    max-width: 700px;
    margin: 0 auto var(--space-2xl);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 900px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar-card {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-card);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    transition: box-shadow var(--transition-base);
  }

  .pillar-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .pillar-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-subtle);
  }

  .pillar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: rgba(200, 240, 74, 0.1);
    border-radius: 10px;
    color: var(--sky-blue);
    flex-shrink: 0;
  }

  .pillar-icon svg {
    display: block;
  }

  .pillar-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--heading-color);
    margin: 0;
  }

  .pillar-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  .pillar-problem p,
  .pillar-solution p,
  .pillar-result p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.7;
    margin: 0;
  }

  /* SECTION 4: PROBLEM */
  .problem-section {
    background-color: var(--page-bg);
  }

  .pain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 900px;
    margin: 0 auto var(--space-xl);
  }

  @media (min-width: 768px) {
    .pain-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pain-item {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    padding: var(--space-6);
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    border-left: 4px solid var(--warning-red);
    font-style: italic;
    box-shadow: var(--shadow-sm);
  }

  .stakes-callout {
    max-width: 700px;
    margin: 0 auto var(--space-8);
    padding: var(--space-6);
    background-color: rgba(220, 38, 38, 0.08);
    border-radius: var(--card-radius);
    border: 2px solid var(--warning-red);
  }

  .stakes-callout p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--warning-red);
    text-align: center;
    margin: 0;
    font-weight: 600;
  }


  /* SECTION 5: DEEP-SCAN FEATURE */
  .deepscan-section {
    background-color: var(--navy);
    position: relative;
  }

  .deepscan-section h2 {
    color: var(--white);
  }

  .deepscan-intro {
    max-width: 700px;
    margin: 0 auto var(--space-xl);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--off-white);
    line-height: 1.7;
  }

  /* Light variant */
  .deepscan-section--light {
    background-color: var(--section-light-bg, var(--page-bg));
  }

  .deepscan-section--light h2 {
    color: var(--heading-color);
  }

  .deepscan-section--light .deepscan-intro {
    color: var(--muted-text);
  }

  .deepscan-section--light .deepscan-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-card);
  }

  .deepscan-section--light .deepscan-card h4 {
    color: var(--heading-color);
  }

  .deepscan-section--light .deepscan-card p {
    color: var(--muted-text);
  }

  .deepscan-section--light .guarantee-text {
    color: var(--emerald);
  }

  .deepscan-section--light .guarantee-sub {
    color: var(--slate);
  }

  .deepscan-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .deepscan-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .deepscan-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .deepscan-card {
    background-color: var(--navy-light);
    border-radius: var(--card-radius);
    padding: var(--space-6);
    transition: transform var(--transition-fast);
    display: flex;
    flex-direction: column;
  }

  .deepscan-card:hover {
    transform: translateY(-4px);
  }

  .deepscan-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: rgba(200, 240, 74, 0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: 4px;
    margin-top: auto;
    padding-top: var(--space-4);
    align-self: flex-start;
  }

  .deepscan-card h4 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--white);
    margin-bottom: var(--space-3);
  }

  .deepscan-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--off-white);
    line-height: 1.6;
    margin: 0;
  }

  .deepscan-guarantee {
    text-align: center;
  }

  .guarantee-text {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--emerald);
    margin-bottom: var(--space-8);
  }

  .guarantee-sub {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--off-white);
    margin-top: var(--space-6);
    opacity: 0.8;
  }

  /* SECTION 6: CASE STUDIES */
  .casestudies-section h2 {
    margin-bottom: var(--space-2xl);
  }

  .case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .case-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .case-card {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-card);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: box-shadow var(--transition-base), transform var(--transition-fast);
  }

  .case-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .case-logo {
    margin-bottom: var(--space-4);
  }

  .case-logo .logo-lockup {
    height: 36px;
  }


  .case-context {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--slate);
    opacity: 0.7;
    margin: var(--space-2) 0 var(--space-4);
  }

  .case-pillar {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .case-card h4 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
    margin: 0;
  }

  .case-metric {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--emerald);
  }

  .case-details {
    flex: 1;
  }

  .case-details p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .case-details strong {
    color: var(--text-color);
    font-weight: 600;
  }

  .case-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-blue);
    margin-top: auto;
    transition: color var(--transition-fast);
  }

  .case-link:hover {
    color: var(--sky-blue-light);
  }

  /* SECTION 6.5: TESTIMONIAL STRIP */
  .testimonial-strip {
    background-color: var(--navy);
    padding: var(--space-section-mobile) 0;
  }

  @media (min-width: 768px) {
    .testimonial-strip {
      padding: var(--space-section) 0;
    }
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .testimonial-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .testimonial-card {
    border-left: 3px solid var(--sky-blue);
    padding-left: var(--space-6);
  }

  .testimonial-quote {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--white);
    line-height: 1.55;
    font-style: italic;
    margin-bottom: var(--space-4);
  }

  .testimonial-attribution {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial-name {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-blue);
  }

  .testimonial-role {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--off-white);
    opacity: 0.65;
  }

  /* SECTION 8: ICP CARDS */
  .icp-section h2 {
    margin-bottom: var(--space-2xl);
  }

  .icp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 900px) {
    .icp-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .icp-card {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-card);
    border-left: 4px solid var(--sky-blue);
    padding: var(--space-7);
    transition: box-shadow var(--transition-base);
  }

  .icp-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .icp-type {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .icp-trigger {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--heading-color);
    font-style: italic;
    margin-bottom: var(--space-4);
  }

  .icp-job {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--slate);
    margin-bottom: var(--space-3);
  }

  .icp-outcome {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--emerald);
    font-weight: 600;
    margin: 0;
  }

  .icp-expand {
    text-align: center;
  }

  .icp-more summary {
