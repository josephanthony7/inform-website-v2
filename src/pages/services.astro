---
import Layout from '../layouts/Layout.astro';
import BrandIcon from '../components/ui/BrandIcon.astro';
---

<Layout
  title="Services - Inform Growth"
  description="We build revenue infrastructure that compounds. From diagnosis to AI-powered systems, everything we build is yours to own and scale."
>
  <!-- Page Header + Process -->
  <section class="page-header section geo-grid">
    <div class="container">
      <div class="header-content fade-up">
        <div class="header-eyebrow">Built For You</div>
        <h1>Your Revenue Engine, Compounding</h1>
        <p class="header-subtitle">
          A systematic approach that starts with understanding and ends with independence. Each step builds on the last, creating compounding value.
        </p>
      </div>

      <!-- Horizontal Process Flow -->
      <div class="process-flow fade-up">
        <div class="flow-step" data-step="1">
          <div class="flow-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </div>
          <div class="flow-label">Explore</div>
          <div class="flow-desc">Audit systems, find leaks</div>
        </div>

        <div class="flow-connector"><span></span></div>

        <div class="flow-step" data-step="2">
          <div class="flow-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>
            </svg>
          </div>
          <div class="flow-label">Codify</div>
          <div class="flow-desc">Define your data truth</div>
        </div>

        <div class="flow-connector"><span></span></div>

        <div class="flow-step" data-step="3">
          <div class="flow-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v4"/><path d="m6.34 6.34 2.83 2.83"/><path d="M2 12h4"/><path d="m6.34 17.66 2.83-2.83"/><path d="M12 18v4"/><path d="m17.66 17.66-2.83-2.83"/><path d="M18 12h4"/><path d="m17.66 6.34-2.83 2.83"/>
            </svg>
          </div>
          <div class="flow-label">Connect</div>
          <div class="flow-desc">Unify your entire stack</div>
        </div>

        <div class="flow-connector"><span></span></div>

        <div class="flow-step" data-step="4">
          <div class="flow-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="flow-label">Empower</div>
          <div class="flow-desc">Train your team on AI</div>
        </div>

        <div class="flow-connector"><span></span></div>

        <div class="flow-step active" data-step="5">
          <div class="flow-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v4"/><path d="M12 18v4"/><path d="m4.93 4.93 2.83 2.83"/><path d="m16.24 16.24 2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="m4.93 19.07 2.83-2.83"/><path d="m16.24 7.76 2.83-2.83"/>
            </svg>
          </div>
          <div class="flow-label">Compound</div>
          <div class="flow-desc">System learns, costs drop</div>
        </div>
      </div>

      <!-- Expandable Detail Cards -->
      <div class="flow-details fade-up">
        <div class="detail-card" data-for="1">
          <span class="detail-num">01</span>
          <div class="detail-content">
            <strong>Full system audit</strong> · Stakeholder interviews · Pipeline analysis · Gap prioritization
          </div>
        </div>
        <div class="detail-card" data-for="2">
          <span class="detail-num">02</span>
          <div class="detail-content">
            <strong>Business glossary</strong> · Field definitions · Validation rules · Process docs
          </div>
        </div>
        <div class="detail-card" data-for="3">
          <span class="detail-num">03</span>
          <div class="detail-content">
            <strong>API integrations</strong> · AI middleware · Real-time sync · Natural language queries
          </div>
        </div>
        <div class="detail-card" data-for="4">
          <span class="detail-num">04</span>
          <div class="detail-content">
            <strong>Team workshops</strong> · Custom playbooks · Prompt libraries · Ongoing support
          </div>
        </div>
        <div class="detail-card active" data-for="5">
          <span class="detail-num">05</span>
          <div class="detail-content">
            <strong>New hires inherit context</strong> · Tools plug in automatically · Value accumulates
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Build: The AI Infrastructure -->
  <section class="infrastructure-section section bg-dark">
    <div class="container">
      <div class="infra-header fade-up">
        <h2>The Infrastructure We Build For You</h2>
        <p>A governed AI layer that sits between your tools and your team. Read-only by default. Your credentials stay with you. Every integration reviewed before it goes live.</p>
      </div>

      <div class="infra-grid fade-up">
        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="data-stack" size={32} />
          </div>
          <h3>One Source of Truth</h3>
          <p>Your team asks questions in plain English. The AI queries your connected tools and returns answers in seconds - with the data definitions you've approved.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="security" size={32} />
          </div>
          <h3>Read-Only by Default</h3>
          <p>The AI can read your systems to answer questions but cannot modify data unless explicitly approved. Your data stays safe.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="integration" size={32} />
          </div>
          <h3>Credentials Stay Local</h3>
          <p>Your API keys and sensitive credentials live on your infrastructure, not ours. We build the connections; you control the access.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="deep-scan" size={32} />
          </div>
          <h3>QA Review on Every Integration</h3>
          <p>Every tool we connect goes through automated and human review before it touches your production systems. No surprises.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="attribution" size={32} />
          </div>
          <h3>Your Team Owns Everything</h3>
          <p>Every workflow, every integration, every definition lives in your infrastructure. We hand it back documented and ready for your team to maintain.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="compounding" size={32} />
          </div>
          <h3>Costs Decrease Over Time</h3>
          <p>As workflows mature, expensive API calls become targeted queries. Your token costs go down as your context gets more precise.</p>
        </div>
      </div>

      <div class="infra-cta fade-up">
        <a href="/security" class="btn btn-secondary">Learn More About Our Security Model</a>
      </div>
    </div>
  </section>

  <!-- Service Tiers -->
  <section class="tiers-section section bg-light">
    <div class="container">
      <div class="tiers-header fade-up">
        <h2>Three Ways to Start</h2>
        <p>Every engagement begins with understanding where you are. From there, we scope what makes sense for your team.</p>
      </div>

      <div class="tiers-grid fade-up">
        <!-- Tier 1 -->
        <div class="tier-card">
          <div class="tier-label">Start Here</div>
          <h3>Deep-Scan</h3>
          <p class="tier-desc">Full audit of your revenue infrastructure. We find what's broken and what's costing you money.</p>
          <div class="tier-guarantee">$100K+ in recoverable pipeline - or you don't pay.</div>
          <ul class="tier-includes">
            <li>CRM and data architecture review</li>
            <li>Pipeline leak analysis</li>
            <li>Prioritized repair roadmap</li>
          </ul>
          <div class="tier-meta">
            <span class="tier-price">$1,500</span>
            <span class="tier-time">1-2 weeks</span>
          </div>
          <a href="/contact" class="btn btn-primary btn-block">Book Deep-Scan</a>
        </div>

        <!-- Tier 2 -->
        <div class="tier-card featured">
          <div class="tier-label">Full Build</div>
          <h3>Revenue Engine Build</h3>
          <p class="tier-desc">End-to-end implementation. AI-powered revenue infrastructure your team owns.</p>
          <ul class="tier-includes">
            <li>Data cleanup and migration</li>
            <li>AI middleware deployment</li>
            <li>Tool integrations</li>
            <li>Training and documentation</li>
          </ul>
          <div class="tier-meta">
            <span class="tier-price">$15K-$40K</span>
            <span class="tier-time">6-12 weeks</span>
          </div>
          <a href="/contact" class="btn btn-primary btn-block">Scope Your Build</a>
        </div>

        <!-- Tier 3 -->
        <div class="tier-card">
          <div class="tier-label">Ongoing</div>
          <h3>Revenue Assurance</h3>
          <p class="tier-desc">Continuous monitoring and support. We keep your engine running and compounding.</p>
          <ul class="tier-includes">
            <li>24/7 monitoring and alerts</li>
            <li>Monthly data quality reports</li>
            <li>Quarterly strategic reviews</li>
          </ul>
          <div class="tier-meta">
            <span class="tier-price">$3K-$5K/mo</span>
            <span class="tier-time">Ongoing</span>
          </div>
          <a href="/contact" class="btn btn-primary btn-block">Get Assurance</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta section bg-dark">
    <div class="container">
      <div class="final-cta-content fade-up">
        <h2>Ready to build a revenue engine that compounds?</h2>
        <a href="/contact" class="btn btn-primary btn-large">Book a Meeting</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background-color: var(--color-bg-surface);
    padding: var(--space-2xl) 0 var(--space-section);
  }

  .header-content {
    max-width: 800px;
    margin: 0 auto var(--space-2xl);
    text-align: center;
  }

  .header-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-md);
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--heading-color);
    line-height: 1.15;
    margin-bottom: var(--space-sm);
  }

  .header-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Horizontal Process Flow */
  .process-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin: 0 auto var(--space-lg);
    max-width: 1200px;
    padding: 0 var(--space-md);
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-md);
    cursor: pointer;
    transition: all 0.3s ease;
    flex: 1;
    max-width: 160px;
  }

  .flow-step:hover .flow-icon,
  .flow-step.active .flow-icon {
    background: var(--color-accent);
    color: #fff;
    transform: scale(1.1);
  }

  .flow-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent-muted);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
    transition: all 0.3s ease;
  }

  .flow-label {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: 4px;
  }

  .flow-desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-tertiary);
    line-height: 1.3;
  }

  .flow-connector {
    display: flex;
    align-items: center;
    padding-top: 28px;
  }

  .flow-connector span {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent-muted), var(--color-accent), var(--color-accent-muted));
    position: relative;
  }

  .flow-connector span::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    border: 4px solid transparent;
    border-left-color: var(--color-accent);
  }

  /* Detail Cards Row */
  .flow-details {
    display: flex;
    gap: var(--space-sm);
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .detail-card {
    flex: 1;
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .detail-card:hover,
  .detail-card.active {
    opacity: 1;
    border-color: var(--color-accent);
  }

  .detail-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    padding: 4px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .detail-content {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .detail-content strong {
    color: var(--heading-color);
  }

  /* Mobile: Stack vertically */
  @media (max-width: 900px) {
    .process-flow {
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .flow-step {
      flex: 0 0 calc(33.333% - var(--space-sm));
      max-width: none;
    }

    .flow-connector {
      display: none;
    }

    .flow-details {
      flex-direction: column;
    }

    .detail-card {
      opacity: 1;
    }
  }

  @media (max-width: 600px) {
    .flow-step {
      flex: 0 0 calc(50% - var(--space-sm));
    }
  }

  /* Infrastructure Section */
  .infrastructure-section {
    background: var(--color-bg-surface);
  }

  .bg-dark {
    background-color: var(--color-bg-surface);
  }

  .infra-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-2xl);
  }

  .infra-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-md);
  }

  .infra-header p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .infra-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  @media (max-width: 1024px) {
    .infra-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .infra-grid {
      grid-template-columns: 1fr;
    }
  }

  .infra-card {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-lg);
    transition: all 0.3s ease;
  }

  .infra-card:hover {
    background: var(--color-bg-raised);
    border-color: var(--sky-blue);
  }

  .infra-icon {
    color: var(--sky-blue);
    margin-bottom: var(--space-md);
  }

  .infra-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-sm);
  }

  .infra-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .infra-cta {
    text-align: center;
  }

  /* Tiers Section */
  .tiers-section {
    background-color: var(--color-bg-base);
  }

  .bg-light {
    background-color: var(--section-light-bg);
  }

  .tiers-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
  }

  .tiers-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-md);
  }

  .tiers-header p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--muted-text);
    line-height: 1.7;
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: stretch;
  }

  @media (max-width: 1024px) {
    .tiers-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  .tier-card {
    background: var(--color-bg-raised);
    border-radius: 12px;
    padding: var(--space-xl);
    border: 2px solid var(--border-subtle);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .tier-card:hover {
    border-color: var(--sky-blue);
  }

  .tier-card.featured {
    border-color: var(--sky-blue);
    box-shadow: 0 8px 30px rgba(45, 80, 22, 0.15);
    position: relative;
  }

  .tier-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .tier-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-sm);
  }

  .tier-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .tier-guarantee {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    padding: var(--space-sm) var(--space-md);
    border-radius: 6px;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .tier-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .tier-includes li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    padding-left: var(--space-lg);
    position: relative;
  }

  .tier-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .tier-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: var(--space-lg);
  }

  .tier-price {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
  }

  .tier-time {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted-text);
  }

  .btn-block {
    display: block;
    text-align: center;
    width: 100%;
  }

  /* Outcomes Section */
  .outcomes-section {
    background-color: var(--page-bg);
  }

  .outcomes-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .outcomes-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--heading-color);
  }

  .outcomes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .outcomes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .outcome-item {
    text-align: center;
    padding: var(--space-lg);
  }

  .outcome-stat {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--sky-blue);
    margin-bottom: var(--space-sm);
  }

  .outcome-item p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.5;
    margin: 0;
  }

  /* Final CTA */
  .final-cta {
    padding: var(--space-3xl) 0;
  }

  .final-cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .final-cta h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-md);
  }

  .final-cta p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: #8C8880;
    margin-bottom: var(--space-xl);
  }

  .btn-large {
    padding: 16px 32px;
    font-size: var(--text-lg);
  }

  /* Scroll animations */
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Scroll-triggered fade-up animations
  document.addEventListener('DOMContentLoaded', () => {
    const fadeElements = document.querySelectorAll('.fade-up');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    fadeElements.forEach(el => observer.observe(el));

    // Interactive process flow
    const flowSteps = document.querySelectorAll('.flow-step');
    const detailCards = document.querySelectorAll('.detail-card');

    flowSteps.forEach(step => {
      step.addEventListener('mouseenter', () => {
        const stepNum = step.dataset.step;
        flowSteps.forEach(s => s.classList.remove('active'));
        detailCards.forEach(c => c.classList.remove('active'));
        step.classList.add('active');
        document.querySelector(`.detail-card[data-for="${stepNum}"]`)?.classList.add('active');
      });
    });

    detailCards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const forStep = card.dataset.for;
        flowSteps.forEach(s => s.classList.remove('active'));
        detailCards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        document.querySelector(`.flow-step[data-step="${forStep}"]`)?.classList.add('active');
      });
    });
  });
</script>
