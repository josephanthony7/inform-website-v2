---
import Layout from '../layouts/Layout.astro';
import BrandIcon from '../components/ui/BrandIcon.astro';
---

<Layout
  title="Services - Inform Growth"
  description="We build revenue infrastructure that compounds. From diagnosis to AI-powered systems, everything we build is yours to own and scale."
>
  <!-- Page Header + Process -->
  <section class="page-header section geo-grid">
    <div class="container">
      <div class="header-content fade-up">
        <div class="header-eyebrow">Built For You</div>
        <h1>Your Revenue Engine, Compounding</h1>
        <p class="header-subtitle">
          A systematic approach that starts with understanding and ends with independence. Each step builds on the last, creating compounding value.
        </p>
      </div>

      <div class="approach-steps fade-up">
        <div class="approach-step">
          <div class="step-marker">01</div>
          <div class="step-content">
            <h3>Explore</h3>
            <p class="step-for-you">We learn your business</p>
            <p>We audit your CRM, data architecture, and sales processes. We interview your team. We find where revenue is leaking and where opportunities are hiding.</p>
            <ul class="step-details">
              <li>Full system and process audit</li>
              <li>Stakeholder interviews</li>
              <li>Statistical analysis of your pipeline</li>
              <li>Gap identification and prioritization</li>
            </ul>
          </div>
        </div>

        <div class="approach-step">
          <div class="step-marker">02</div>
          <div class="step-content">
            <h3>Codify</h3>
            <p class="step-for-you">We document your truth</p>
            <p>We define what your data means in your specific business context. Pipeline stages, ARR rules, field definitions - documented once, applied everywhere.</p>
            <ul class="step-details">
              <li>Business glossary and field registry</li>
              <li>Pipeline stage definitions</li>
              <li>Data validation rules</li>
              <li>Process documentation</li>
            </ul>
          </div>
        </div>

        <div class="approach-step">
          <div class="step-marker">03</div>
          <div class="step-content">
            <h3>Connect</h3>
            <p class="step-for-you">We integrate your tools</p>
            <p>One AI middleware layer connects your entire stack. HubSpot, Salesforce, Gong, Apollo, Clay - every tool feeds into one source of truth that your whole team can query.</p>
            <ul class="step-details">
              <li>API integrations and webhooks</li>
              <li>AI middleware deployment</li>
              <li>Real-time data synchronization</li>
              <li>Natural language query interface</li>
            </ul>
          </div>
        </div>

        <div class="approach-step">
          <div class="step-marker">04</div>
          <div class="step-content">
            <h3>Empower</h3>
            <p class="step-for-you">We train your team</p>
            <p>We coach your revenue teams to leverage AI with their tools. Not just training - hands-on enablement that changes how they work every day.</p>
            <ul class="step-details">
              <li>Team workshops and training</li>
              <li>Custom playbooks and templates</li>
              <li>AI prompt libraries for your context</li>
              <li>Ongoing office hours and support</li>
            </ul>
          </div>
        </div>

        <div class="approach-step final">
          <div class="step-marker">05</div>
          <div class="step-content">
            <h3>Compound</h3>
            <p class="step-for-you">Your system gets smarter</p>
            <p>Every question your team asks, every workflow that gets promoted to shared infrastructure, makes the next one faster and cheaper. The system learns what works.</p>
            <ul class="step-details">
              <li>New hires inherit full context</li>
              <li>New tools plug in automatically</li>
              <li>Best practices scale across teams</li>
              <li>Value accumulates over time</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Build: The AI Infrastructure -->
  <section class="infrastructure-section section bg-dark">
    <div class="container">
      <div class="infra-header fade-up">
        <h2>The Infrastructure We Build For You</h2>
        <p>A governed AI layer that sits between your tools and your team. Read-only by default. Your credentials stay with you. Every integration reviewed before it goes live.</p>
      </div>

      <div class="infra-grid fade-up">
        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="data-stack" size={32} />
          </div>
          <h3>One Source of Truth</h3>
          <p>Your team asks questions in plain English. The AI queries your connected tools and returns answers in seconds - with the data definitions you've approved.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="security" size={32} />
          </div>
          <h3>Read-Only by Default</h3>
          <p>The AI can read your systems to answer questions but cannot modify data unless explicitly approved. Your data stays safe.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="integration" size={32} />
          </div>
          <h3>Credentials Stay Local</h3>
          <p>Your API keys and sensitive credentials live on your infrastructure, not ours. We build the connections; you control the access.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="deep-scan" size={32} />
          </div>
          <h3>QA Review on Every Integration</h3>
          <p>Every tool we connect goes through automated and human review before it touches your production systems. No surprises.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="attribution" size={32} />
          </div>
          <h3>Your Team Owns Everything</h3>
          <p>Every workflow, every integration, every definition lives in your infrastructure. We hand it back documented and ready for your team to maintain.</p>
        </div>

        <div class="infra-card">
          <div class="infra-icon">
            <BrandIcon name="compounding" size={32} />
          </div>
          <h3>Costs Decrease Over Time</h3>
          <p>As workflows mature, expensive API calls become targeted queries. Your token costs go down as your context gets more precise.</p>
        </div>
      </div>

      <div class="infra-cta fade-up">
        <a href="/security" class="btn btn-secondary">Learn More About Our Security Model</a>
      </div>
    </div>
  </section>

  <!-- Service Tiers -->
  <section class="tiers-section section bg-light">
    <div class="container">
      <div class="tiers-header fade-up">
        <h2>Three Ways to Start</h2>
        <p>Every engagement begins with understanding where you are. From there, we scope what makes sense for your team.</p>
      </div>

      <div class="tiers-grid fade-up">
        <!-- Tier 1 -->
        <div class="tier-card">
          <div class="tier-label">Start Here</div>
          <h3>Deep-Scan</h3>
          <p class="tier-desc">Full audit of your revenue infrastructure. We find what's broken and what's costing you money.</p>
          <div class="tier-guarantee">$100K+ in recoverable pipeline - or you don't pay.</div>
          <ul class="tier-includes">
            <li>CRM and data architecture review</li>
            <li>Pipeline leak analysis</li>
            <li>Prioritized repair roadmap</li>
          </ul>
          <div class="tier-meta">
            <span class="tier-price">$1,500</span>
            <span class="tier-time">1-2 weeks</span>
          </div>
          <a href="/contact" class="btn btn-primary btn-block">Book Deep-Scan</a>
        </div>

        <!-- Tier 2 -->
        <div class="tier-card featured">
          <div class="tier-label">Full Build</div>
          <h3>Revenue Engine Build</h3>
          <p class="tier-desc">End-to-end implementation. AI-powered revenue infrastructure your team owns.</p>
          <ul class="tier-includes">
            <li>Data cleanup and migration</li>
            <li>AI middleware deployment</li>
            <li>Tool integrations</li>
            <li>Training and documentation</li>
          </ul>
          <div class="tier-meta">
            <span class="tier-price">$15K-$40K</span>
            <span class="tier-time">6-12 weeks</span>
          </div>
          <a href="/contact" class="btn btn-primary btn-block">Scope Your Build</a>
        </div>

        <!-- Tier 3 -->
        <div class="tier-card">
          <div class="tier-label">Ongoing</div>
          <h3>Revenue Assurance</h3>
          <p class="tier-desc">Continuous monitoring and support. We keep your engine running and compounding.</p>
          <ul class="tier-includes">
            <li>24/7 monitoring and alerts</li>
            <li>Monthly data quality reports</li>
            <li>Quarterly strategic reviews</li>
          </ul>
          <div class="tier-meta">
            <span class="tier-price">$3K-$5K/mo</span>
            <span class="tier-time">Ongoing</span>
          </div>
          <a href="/contact" class="btn btn-primary btn-block">Get Assurance</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta section bg-dark">
    <div class="container">
      <div class="final-cta-content fade-up">
        <h2>Ready to build a revenue engine that compounds?</h2>
        <a href="/contact" class="btn btn-primary btn-large">Book a Meeting</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background-color: var(--color-bg-surface);
    padding: var(--space-2xl) 0 var(--space-section);
  }

  .header-content {
    max-width: 800px;
    margin: 0 auto var(--space-2xl);
    text-align: center;
  }

  .header-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-md);
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: white;
    line-height: 1.15;
    margin-bottom: var(--space-sm);
  }

  .header-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .approach-steps {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .approach-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-bg-raised);
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: all 0.3s ease;
  }

  .approach-step:hover {
    border-color: var(--sky-blue);
    box-shadow: 0 4px 20px rgba(200, 240, 74, 0.1);
  }

  .approach-step.final {
    border-color: #C8F04A;
    background: var(--color-bg-raised);
  }

  .approach-step.final:hover {
    box-shadow: 0 4px 20px rgba(200, 240, 74, 0.15);
  }

  .step-marker {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--sky-blue);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(200, 240, 74, 0.1);
    border-radius: 12px;
  }

  .approach-step.final .step-marker {
    color: #C8F04A;
    background: rgba(200, 240, 74, 0.1);
  }

  .step-content h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-xs);
  }

  .step-for-you {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-blue);
    margin-bottom: var(--space-sm);
  }

  .approach-step.final .step-for-you {
    color: #C8F04A;
  }

  .step-content > p:not(.step-for-you) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--muted-text);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .step-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xs) var(--space-lg);
  }

  .step-details li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    padding-left: var(--space-md);
    position: relative;
  }

  .step-details li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--sky-blue);
    font-weight: 600;
  }

  .approach-step.final .step-details li::before {
    color: #C8F04A;
  }

  @media (max-width: 768px) {
    .approach-step {
      grid-template-columns: 1fr;
    }

    .step-marker {
      width: 48px;
      height: 48px;
      font-size: var(--text-lg);
    }

    .step-details {
      grid-template-columns: 1fr;
    }
  }

  /* Infrastructure Section */
  .infrastructure-section {
    background: #0D0D0B;
  }

  .bg-dark {
    background-color: var(--color-bg-surface);
  }

  .infra-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-2xl);
  }

  .infra-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: white;
    margin-bottom: var(--space-md);
  }

  .infra-header p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: #8C8880;
    line-height: 1.7;
  }

  .infra-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  @media (max-width: 1024px) {
    .infra-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .infra-grid {
      grid-template-columns: 1fr;
    }
  }

  .infra-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: var(--space-lg);
    transition: all 0.3s ease;
  }

  .infra-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--sky-blue);
  }

  .infra-icon {
    color: var(--sky-blue);
    margin-bottom: var(--space-md);
  }

  .infra-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: white;
    margin-bottom: var(--space-sm);
  }

  .infra-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: #8C8880;
    line-height: 1.6;
    margin: 0;
  }

  .infra-cta {
    text-align: center;
  }

  /* Tiers Section */
  .tiers-section {
    background-color: var(--color-bg-base);
  }

  .bg-light {
    background-color: var(--section-light-bg);
  }

  .tiers-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
  }

  .tiers-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-md);
  }

  .tiers-header p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--muted-text);
    line-height: 1.7;
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: stretch;
  }

  @media (max-width: 1024px) {
    .tiers-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  .tier-card {
    background: var(--color-bg-raised);
    border-radius: 12px;
    padding: var(--space-xl);
    border: 2px solid var(--border-subtle);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .tier-card:hover {
    border-color: var(--sky-blue);
  }

  .tier-card.featured {
    border-color: var(--sky-blue);
    box-shadow: 0 8px 30px rgba(200, 240, 74, 0.15);
    position: relative;
  }

  .tier-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .tier-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-sm);
  }

  .tier-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .tier-guarantee {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #C8F04A;
    background: rgba(200, 240, 74, 0.1);
    padding: var(--space-sm) var(--space-md);
    border-radius: 6px;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .tier-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .tier-includes li {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    padding-left: var(--space-lg);
    position: relative;
  }

  .tier-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #C8F04A;
    font-weight: 700;
  }

  .tier-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: var(--space-lg);
  }

  .tier-price {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--heading-color);
  }

  .tier-time {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted-text);
  }

  .btn-block {
    display: block;
    text-align: center;
    width: 100%;
  }

  /* Outcomes Section */
  .outcomes-section {
    background-color: var(--page-bg);
  }

  .outcomes-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .outcomes-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--heading-color);
  }

  .outcomes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .outcomes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .outcome-item {
    text-align: center;
    padding: var(--space-lg);
  }

  .outcome-stat {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--sky-blue);
    margin-bottom: var(--space-sm);
  }

  .outcome-item p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.5;
    margin: 0;
  }

  /* Final CTA */
  .final-cta {
    padding: var(--space-3xl) 0;
  }

  .final-cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .final-cta h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 900;
    color: white;
    margin-bottom: var(--space-md);
  }

  .final-cta p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: #8C8880;
    margin-bottom: var(--space-xl);
  }

  .btn-large {
    padding: 16px 32px;
    font-size: var(--text-lg);
  }

  /* Scroll animations */
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Scroll-triggered fade-up animations
  document.addEventListener('DOMContentLoaded', () => {
    const fadeElements = document.querySelectorAll('.fade-up');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    fadeElements.forEach(el => observer.observe(el));
  });
</script>
