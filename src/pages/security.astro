---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Security - Inform Growth | AI Layer Security & Governance"
  description="Our AI layer is read-only by default. Your credentials stay local. Every integration is QA reviewed. Enterprise-grade security because your data is not our product."
>
  <!-- Page Header + Architecture -->
  <section class="page-header section geo-grid">
    <div class="container">
      <div class="header-content fade-up">
        <div class="header-eyebrow">Security & Governance</div>
        <h1>Your Data. Your Infrastructure. Your Control.</h1>
        <p class="header-subtitle">
          Most AI tools train on your data. Ours doesn't. We build a governed AI layer on YOUR infrastructure. Read-only by default. Your credentials never leave your servers. Every integration human-reviewed before production.
        </p>
      </div>
    </div>
  </section>

  <!-- Architecture Diagram -->
  <section class="section arch-section">
    <div class="container">
      <div class="architecture-intro fade-up">

      <div class="architecture-diagram fade-up">
        <!-- SVG Flow Visualization -->
        <div class="arch-visual">
          <svg class="arch-svg" viewBox="0 0 900 200" preserveAspectRatio="xMidYMid meet">
            <defs>
              <linearGradient id="archGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#2D5016" />
                <stop offset="100%" stop-color="#2D5016" />
              </linearGradient>
              <radialGradient id="hubGlowSec" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#2D5016" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="#2D5016" stop-opacity="0"/>
              </radialGradient>
              <!-- Subtle grid pattern -->
              <pattern id="archGrid" width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="10" cy="10" r="0.5" fill="rgba(45,80,22,0.1)"/>
              </pattern>
            </defs>

            <!-- Background grid -->
            <rect width="900" height="200" fill="url(#archGrid)"/>

            <!-- Flow track background -->
            <path d="M 170 100 Q 300 100 450 100 Q 600 100 730 100" stroke="#E5E5E0" stroke-width="3" fill="none" stroke-linecap="round"/>

            <!-- Animated flow line -->
            <path d="M 170 100 Q 300 100 450 100 Q 600 100 730 100" stroke="url(#archGradient)" stroke-width="3" fill="none" stroke-linecap="round" class="arch-flow-line"/>

            <!-- Animated particle -->
            <circle r="5" fill="#2D5016" class="arch-particle">
              <animateMotion dur="4s" repeatCount="indefinite" path="M 170 100 L 730 100 L 170 100" keyPoints="0;0.5;1" keyTimes="0;0.5;1" calcMode="linear" />
            </circle>

            <!-- Node 1: Your Team -->
            <g class="arch-node-svg" transform="translate(100, 100)">
              <rect x="-55" y="-55" width="110" height="110" rx="16" fill="#FFFFFF" stroke="#E5E5E0" stroke-width="2" class="node-rect"/>
              <!-- User icon - professional style -->
              <circle cx="0" cy="-12" r="18" fill="#E8F5D0" stroke="#2D5016" stroke-width="2"/>
              <circle cx="0" cy="-16" r="8" fill="#2D5016"/>
              <path d="M -12 0 Q -12 -8 0 -8 Q 12 -8 12 0" fill="#2D5016"/>
              <text y="30" text-anchor="middle" fill="#1A1A18" font-family="'DM Sans',system-ui,sans-serif" font-size="13" font-weight="700">Your Team</text>
            </g>

            <!-- Node 2: AI Gateway (center hub) -->
            <g class="arch-node-svg arch-hub-svg" transform="translate(450, 100)">
              <!-- Outer glow -->
              <circle r="80" fill="url(#hubGlowSec)" class="hub-glow-bg"/>
              <!-- Rotating ring -->
              <circle r="68" fill="none" stroke="rgba(45,80,22,0.2)" stroke-width="1" stroke-dasharray="8 6">
                <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="20s" repeatCount="indefinite"/>
              </circle>
              <!-- Main hub circle -->
              <circle r="55" fill="#FFFFFF" stroke="#2D5016" stroke-width="2.5" class="hub-core"/>
              <!-- Anthropic icon -->
              <g transform="translate(-12, -22)">
                <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/anthropic.svg" width="24" height="24" style="filter:brightness(0) saturate(0)"/>
              </g>
              <text y="12" text-anchor="middle" font-family="'Inter',system-ui,sans-serif" font-size="9" font-weight="700" fill="#1A1A18" letter-spacing="0.08em">INFORM GROWTH</text>
            </g>

            <!-- Node 3: Your Systems - with real logos -->
            <g class="arch-node-svg" transform="translate(800, 100)">
              <rect x="-55" y="-55" width="110" height="110" rx="16" fill="#FFFFFF" stroke="#2D5016" stroke-width="2" class="node-rect"/>
              <!-- Tool logos grid -->
              <g transform="translate(-32, -35)">
                <image href="/logos/hubspot.png" width="28" height="28" preserveAspectRatio="xMidYMid meet"/>
              </g>
              <g transform="translate(4, -35)">
                <image href="/logos/salesforce.png" width="28" height="28" preserveAspectRatio="xMidYMid meet"/>
              </g>
              <g transform="translate(-14, -5)">
                <image href="/logos/attio.png" width="28" height="28" preserveAspectRatio="xMidYMid meet"/>
              </g>
              <text y="42" text-anchor="middle" fill="#1A1A18" font-family="'DM Sans',system-ui,sans-serif" font-size="12" font-weight="700">Your Systems</text>
            </g>
          </svg>
        </div>

        <!-- Mobile fallback layout -->
        <div class="arch-mobile">
          <div class="arch-mobile-node">
            <div class="arch-mobile-icon user-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="8" r="4" fill="#2D5016"/>
                <path d="M4 20c0-4 4-6 8-6s8 2 8 6" fill="#2D5016"/>
              </svg>
            </div>
            <div class="arch-mobile-text">
              <span class="arch-mobile-label">Your Team</span>
            </div>
          </div>
          <div class="arch-mobile-arrow">↓</div>
          <div class="arch-mobile-node hub">
            <div class="arch-mobile-icon">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/anthropic.svg" width="24" height="24" alt="AI" style="filter:brightness(0) saturate(0)"/>
            </div>
            <div class="arch-mobile-text">
              <span class="arch-mobile-label">Inform Growth</span>
            </div>
          </div>
          <div class="arch-mobile-arrow">↓</div>
          <div class="arch-mobile-node systems">
            <div class="arch-mobile-logos">
              <img src="/logos/hubspot.png" width="24" height="24" alt="HubSpot"/>
              <img src="/logos/salesforce.png" width="24" height="24" alt="Salesforce"/>
            </div>
            <div class="arch-mobile-text">
              <span class="arch-mobile-label">Your Systems</span>
            </div>
          </div>
        </div>

        <p class="arch-caption">Data flows through middleware but never leaves your infrastructure</p>
      </div>
    </div>
  </section>

  <!-- Security Principles -->
  <section class="section bg-light">
    <div class="container">
      <h2 class="text-center fade-up">Built-In Security Principles</h2>

      <div class="security-grid fade-up">
        <div class="security-card">
          <div class="security-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3>Read-Only by Default</h3>
          <p>Every integration starts read-only. Mutating operations (POST, DELETE, UPDATE) require explicit admin sign-off before they go live.</p>
        </div>

        <div class="security-card">
          <div class="security-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Credentials Stay Local</h3>
          <p>API keys and credentials are stored in your infrastructure - never in our codebase, never in shared repositories, never exposed to AI models.</p>
        </div>

        <div class="security-card">
          <div class="security-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <h3>Automated QA Review</h3>
          <p>Every workflow promotion goes through automated checks for hardcoded credentials, unsafe operations, and code quality before human review.</p>
        </div>

        <div class="security-card">
          <div class="security-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="8.5" cy="7" r="4"/>
              <polyline points="17 11 19 13 23 9"/>
            </svg>
          </div>
          <h3>Human Approval Gate</h3>
          <p>One mandatory human gate: the merge decision. Admins see clear summaries and explicitly approve before any workflow goes to production.</p>
        </div>

        <div class="security-card">
          <div class="security-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3>Field Validation</h3>
          <p>A centralized field registry documents what your data means. Every promoted tool inherits validation wrappers that enforce data integrity.</p>
        </div>

        <div class="security-card">
          <div class="security-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </div>
          <h3>No Third-Party Training</h3>
          <p>Your data is never used to train external AI models. The AI layer answers questions about your data - it doesn't learn from it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Governance -->
  <section class="section">
    <div class="container">
      <div class="governance-content">
        <div class="governance-text fade-up">
          <h2>Governance</h2>
          <p class="governance-lead">
            Zero ongoing maintenance burden. The governance layer applies uniformly to every tool from every team.
          </p>
          <ul class="governance-list">
            <li>
              <strong>Version controlled:</strong> Every change is tracked, auditable, and reversible
            </li>
            <li>
              <strong>PR-based workflow:</strong> Changes go through structured review before merge
            </li>
            <li>
              <strong>Automated checks:</strong> QA agents review every PR and post pass/fail results
            </li>
            <li>
              <strong>Clear ownership:</strong> Admins control what gets promoted to shared infrastructure
            </li>
            <li>
              <strong>Migration summaries:</strong> See exactly what changes before approving
            </li>
          </ul>
        </div>
        <div class="governance-visual fade-up">
          <div class="gov-flow">
            <div class="gov-step">
              <span class="gov-num">1</span>
              <span class="gov-label">Explore</span>
              <span class="gov-desc">Teams develop in local sandbox</span>
            </div>
            <div class="gov-connector"></div>
            <div class="gov-step">
              <span class="gov-num">2</span>
              <span class="gov-label">Codify</span>
              <span class="gov-desc">Valuable workflows submitted</span>
            </div>
            <div class="gov-connector"></div>
            <div class="gov-step">
              <span class="gov-num">3</span>
              <span class="gov-label">Review</span>
              <span class="gov-desc">Automated QA + human approval</span>
            </div>
            <div class="gov-connector"></div>
            <div class="gov-step">
              <span class="gov-num">4</span>
              <span class="gov-label">Promote</span>
              <span class="gov-desc">Shared infrastructure inherits</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-light">
    <div class="container">
      <h2 class="text-center fade-up">Security FAQs</h2>

      <div class="faq-grid fade-up">
        <details class="faq-item">
          <summary class="faq-question">Where does my data actually go?</summary>
          <div class="faq-answer">
            <p>Nowhere external. The AI layer runs as middleware in your infrastructure. When you ask a question, it routes the request to your systems (HubSpot, Salesforce, etc.), fetches the data server-side, and returns the answer. Your data never leaves your deployment.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Can the AI modify our data?</summary>
          <div class="faq-answer">
            <p>Not without explicit approval. All integrations are read-only by default. Any workflow that includes mutating operations (creating records, updating fields, deleting data) requires admin sign-off through the PR review process before it can go live.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Who has access to our credentials?</summary>
          <div class="faq-answer">
            <p>Only your team. Operator credentials stay in local, untracked .env files. Centralized integrations use server-side credential management that your admins control. No credentials are ever stored in the repository or exposed to AI processing.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Is our data used to train AI models?</summary>
          <div class="faq-answer">
            <p>No. The AI layer we build is a query engine, not a training pipeline. It uses AI to interpret questions and format answers, but your data is never sent to third-party training systems. Your pipeline data stays yours.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What happens if something goes wrong?</summary>
          <div class="faq-answer">
            <p>Everything is version controlled. Any change can be rolled back instantly through Git. The PR-based workflow means you have a complete audit trail of who changed what, when, and why. And read-only defaults mean the worst case is usually just a failed query, not corrupted data.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you have SOC 2 / compliance certifications?</summary>
          <div class="faq-answer">
            <p>The architecture is designed so that compliance depends on your infrastructure, not ours. Because your data never leaves your systems and credentials stay on your deployment, your existing compliance posture extends to the AI layer. We're happy to walk through the architecture with your security team.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bottom-cta geo-grid">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to explore?</h2>
        <a href="/contact" class="btn btn-primary btn-large">Book a Meeting</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background-color: var(--color-bg-base);
    padding: var(--space-2xl) 0 var(--space-lg);
  }

  .header-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .header-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--heading-color);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .header-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Architecture */
  .arch-section {
    padding-top: var(--space-lg);
  }

  .architecture-intro {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-lg);
  }

  .architecture-intro h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-4);
  }

  .architecture-intro p {
    font-size: var(--text-lg);
    color: var(--muted-text);
    line-height: 1.7;
  }

  .architecture-intro .arch-transparency {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-top: var(--space-md);
  }

  .architecture-diagram {
    background: var(--card-bg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--card-radius);
    padding: var(--space-xl) var(--space-md);
    max-width: 900px;
    margin: 0 auto;
    overflow: hidden;
  }

  /* SVG Architecture Visual */
  .arch-visual {
    display: block;
  }

  .arch-svg {
    width: 100%;
    height: auto;
    max-height: 200px;
  }

  .arch-flow-line {
    stroke-dasharray: 540;
    stroke-dashoffset: 540;
    animation: drawArchLine 2s ease-out forwards;
  }

  @keyframes drawArchLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  .arch-particle {
    opacity: 0.8;
  }

  .node-bg {
    transition: all 0.3s ease;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.08));
  }

  .arch-node-svg:hover .node-bg {
    filter: drop-shadow(0 4px 16px rgba(200, 240, 74, 0.25));
  }

  .hub-pulse {
    animation: hubPulse 3s ease-in-out infinite;
  }

  @keyframes hubPulse {
    0%, 100% {
      filter: drop-shadow(0 0 8px rgba(200, 240, 74, 0.3));
    }
    50% {
      filter: drop-shadow(0 0 20px rgba(200, 240, 74, 0.5));
    }
  }

  .arrow-pulse {
    animation: arrowFade 2s ease-in-out infinite;
  }

  .arrow-delay {
    animation-delay: 0.5s;
  }

  @keyframes arrowFade {
    0%, 100% {
      opacity: 0.4;
    }
    50% {
      opacity: 1;
    }
  }

  .node-rect {
    transition: all 0.3s ease;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.06));
  }

  .arch-node-svg:hover .node-rect {
    filter: drop-shadow(0 4px 16px rgba(200, 240, 74, 0.15));
  }

  .hub-glow-bg {
    animation: hubGlowPulse 3s ease-in-out infinite;
  }

  @keyframes hubGlowPulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .hub-core {
    filter: drop-shadow(0 0 12px rgba(200, 240, 74, 0.3));
  }

  /* Mobile fallback */
  .arch-mobile {
    display: none;
  }

  @media (max-width: 700px) {
    .arch-visual {
      display: none;
    }

    .arch-mobile {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-md) 0;
    }

    .arch-mobile-node {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      background: var(--color-bg-raised);
      border: 2px solid var(--border-subtle);
      border-radius: 16px;
      padding: var(--space-md) var(--space-lg);
      width: 100%;
      max-width: 280px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .arch-mobile-node.hub {
      background: var(--color-bg-base);
      border-color: var(--color-accent);
    }

    .arch-mobile-node.hub .arch-mobile-label {
      color: var(--heading-color);
    }

    .arch-mobile-node.hub .arch-mobile-sub {
      color: var(--sky-blue);
    }

    .arch-mobile-node.systems {
      border-color: var(--color-accent);
    }

    .arch-mobile-icon {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .arch-mobile-icon.user-icon {
      background: var(--color-accent-muted);
      border-radius: 50%;
      padding: 4px;
    }

    .arch-mobile-logos {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }

    .arch-mobile-logos img {
      width: 28px;
      height: 28px;
      object-fit: contain;
    }

    .arch-mobile-text {
      display: flex;
      flex-direction: column;
    }

    .arch-mobile-label {
      font-family: var(--font-display);
      font-size: var(--text-base);
      font-weight: 700;
      color: var(--heading-color);
    }

    .arch-mobile-sub {
      font-size: var(--text-sm);
      color: var(--muted-text);
    }

    .arch-mobile-arrow {
      font-size: var(--text-xl);
      color: var(--sky-blue);
      font-weight: 700;
    }
  }

  .arch-caption {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--muted-text);
    margin-top: var(--space-lg);
    font-style: italic;
  }

  /* Security Grid */
  .security-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .security-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .security-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .security-card {
    background: var(--card-bg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
    transition: all var(--transition-base);
  }

  .security-card:hover {
    border-color: var(--sky-blue);
    box-shadow: var(--shadow-lg);
  }

  .security-icon {
    color: var(--sky-blue);
    margin-bottom: var(--space-4);
  }

  .security-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-3);
  }

  .security-card p {
    font-size: var(--text-sm);
    color: var(--muted-text);
    line-height: 1.7;
  }

  /* Governance */
  .governance-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  @media (min-width: 900px) {
    .governance-content {
      grid-template-columns: 1fr 1fr;
    }
  }

  .governance-text h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: var(--space-4);
  }

  .governance-lead {
    font-size: var(--text-lg);
    color: var(--muted-text);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .governance-list {
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-lg);
  }

  .governance-list li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-subtle);
