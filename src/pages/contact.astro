---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact - Inform Growth | Book Your Deep-Scan"
  description="Book a Deep-Scan to find $100K+ in leaked pipeline - or you don't pay. We'll map your entire revenue stack and show you what's costing you."
>
  <!-- Page Header -->
  <section class="page-header section geo-grid">
    <div class="container">
      <div class="header-content fade-up">
        <h1 class="text-center">Let's Find What You're Leaking</h1>
        <p class="header-subtitle text-center">
          Book a 30-minute Deep-Scan call. We'll map your entire revenue stack - every tool, every integration, where data is exposed, and where pipeline is stuck. $100K+ in recoverable pipeline or you don't pay.
        </p>
      </div>
    </div>
  </section>

  <!-- Calendar Section -->
  <section class="section calendar-section">
    <div class="container">
      <div class="calendar-grid">
        <div class="calendar-info">
          <h2>Book Your Deep-Scan</h2>
          <h3>What to Expect:</h3>
          <ul class="expect-list">
            <li>We'll inventory every tool in your revenue stack across Sales, Marketing, and CS</li>
            <li>You'll see where context is fragmenting and data is leaking</li>
            <li>We'll identify the pipeline stuck in your CRM right now</li>
            <li>No pitch until you see the diagnosis - if there's no $100K+ opportunity, we'll tell you</li>
          </ul>
        </div>
        <div class="calendar-embed">
          <!-- Step 1: Prequalification Form -->
          <div id="prequal-form-wrapper">
            <h3 class="prequal-heading">Quick Info Before We Book</h3>
            <p class="prequal-sub">Takes 30 seconds - helps us prepare for the call.</p>
            <form id="prequalForm" class="prequal-form">
              <div class="form-row">
                <div class="form-group">
                  <label for="prequal-name">Name *</label>
                  <input type="text" id="prequal-name" required placeholder="Jane Smith" />
                </div>
                <div class="form-group">
                  <label for="prequal-email">Work Email *</label>
                  <input type="email" id="prequal-email" required placeholder="jane@acmecorp.com" />
                </div>
              </div>
              <div class="form-group">
                <label for="prequal-company">Company *</label>
                <input type="text" id="prequal-company" required placeholder="Acme Corp" />
              </div>
              <div class="form-group">
                <label for="prequal-help">How can we help?</label>
                <textarea id="prequal-help" rows="3" placeholder="Tell us briefly what's going on with your revenue stack..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-full">Book a Call</button>
            </form>
          </div>

          <!-- Step 2: Calendar (hidden until form submitted) -->
          <div id="calendar-wrapper" class="calendar-hidden">
            <div class="prequal-summary" id="prequal-summary"></div>
            <div
              id="calendly-widget"
              class="calendly-inline-widget"
              style="width:100%;min-width:0;height:700px;"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Info Section -->
  <section class="section contact-info">
    <div class="container">
      <div class="info-grid">
        <div class="info-card">
          <h3>Email</h3>
          <a href="mailto:hello@informgrowth.com" class="info-link">hello@informgrowth.com</a>
          <p>We typically respond within 24 hours</p>
        </div>
        <div class="info-card">
          <h3>Connect</h3>
          <a href="https://www.linkedin.com/in/jaron-sander" target="_blank" rel="noopener noreferrer" class="info-link">Jaron on LinkedIn</a>
          <a href="https://www.linkedin.com/in/joseph-anthony/" target="_blank" rel="noopener noreferrer" class="info-link">Joseph on LinkedIn</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendly widget script -->
  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>

  <script is:inline>
    // --- Supabase config (from env at build time, or empty) ---
    var SUPABASE_URL = '';
    var SUPABASE_ANON_KEY = '';

    // --- Supabase helper ---
    function submitToSupabase(payload) {
      if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
        console.warn('Supabase not configured - skipping lead capture.');
        return;
      }
      fetch(SUPABASE_URL + '/rest/v1/inbound_leads', {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(payload),
      }).catch(function(err) {
        console.error('Lead capture error:', err);
      });
    }

    // --- GTM dataLayer helper ---
    window.dataLayer = window.dataLayer || [];
    function pushGTMEvent(eventName, data) {
      window.dataLayer.push(Object.assign({ event: eventName }, data || {}));
    }

    // --- Wait for Calendly script to load ---
    function waitForCalendly(callback, attempts) {
      attempts = attempts || 0;
      if (window.Calendly) {
        callback();
      } else if (attempts < 50) {
        setTimeout(function() { waitForCalendly(callback, attempts + 1); }, 200);
      } else {
        console.error('Calendly failed to load');
      }
    }

    // --- Prequalification form → Supabase + show calendar ---
    document.getElementById('prequalForm').addEventListener('submit', function(e) {
      e.preventDefault();

      var name = document.getElementById('prequal-name').value.trim();
      var email = document.getElementById('prequal-email').value.trim();
      var company = document.getElementById('prequal-company').value.trim();
      var helpText = document.getElementById('prequal-help').value.trim();

      // Push to GTM dataLayer
      pushGTMEvent('prequal_form_submit', {
        form_name: 'prequal_booking',
        user_email: email,
        user_company: company
      });

      // Save lead to Supabase (fire and forget)
      submitToSupabase({
        name: name,
        email: email,
        company: company,
        message: helpText || null,
        source: 'prequal_booking',
      });

      // Build Calendly URL with prefilled params
      var params = new URLSearchParams();
      if (name) params.set('name', name);
      if (email) params.set('email', email);
      if (company) params.set('a1', company);

      var calendlyUrl = 'https://calendly.com/josephdeeanthony/30min?' + params.toString();

      // Show summary bar
      var summary = document.getElementById('prequal-summary');
      summary.innerHTML = '<span>Booking for <strong>' + name + '</strong> at <strong>' + company + '</strong></span>' +
        '<button type="button" id="back-to-form" class="prequal-edit-link">Edit info</button>';

      document.getElementById('back-to-form').addEventListener('click', function() {
        document.getElementById('prequal-form-wrapper').style.display = 'block';
        document.getElementById('calendar-wrapper').classList.add('calendar-hidden');
      });

      // Swap views
      document.getElementById('prequal-form-wrapper').style.display = 'none';
      document.getElementById('calendar-wrapper').classList.remove('calendar-hidden');

      // Clear any existing widget content and initialize Calendly after container is visible
      var widget = document.getElementById('calendly-widget');
      widget.innerHTML = '';

      // Small delay to ensure container is rendered before Calendly initializes
      setTimeout(function() {
        waitForCalendly(function() {
          window.Calendly.initInlineWidget({
            url: calendlyUrl,
            parentElement: widget,
          });
        });
      }, 100);
    });

  </script>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background-color: var(--color-bg-base);
  }

  .header-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-md);
  }

  .header-subtitle {
    font-size: var(--text-lg);
    color: var(--slate);
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Calendar Section */
  .calendar-section {
    background-color: var(--color-bg-surface);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-2xl);
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .calendar-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .calendar-info h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-xs);
  }

  .calendar-info h3 {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--sky-blue);
    margin-bottom: var(--space-sm);
    margin-top: var(--space-md);
  }

  .expect-list {
    list-style: none;
    padding: 0;
    margin-bottom: 0;
  }

  .expect-list li {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--muted-text);
    padding: var(--space-sm) 0;
    padding-left: var(--space-lg);
    position: relative;
    line-height: 1.5;
  }

  .expect-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--sky-blue);
    font-weight: 700;
    font-size: var(--text-lg);
  }

  /* Prequalification Form */
  #prequal-form-wrapper {
    background-color: var(--card-bg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--card-radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
  }

  @media (min-width: 768px) {
    #prequal-form-wrapper {
      padding: var(--space-xl);
    }
  }

  .prequal-heading {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 900;
    color: var(--heading-color);
    margin-bottom: var(--space-xs);
  }

  .prequal-sub {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--slate);
    margin-bottom: var(--space-md);
  }

  .prequal-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .calendar-embed {
    overflow: hidden;
    max-width: 100%;
  }

  .calendar-hidden {
    display: none;
  }

  .prequal-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--body-text);
    padding: var(--space-sm) var(--space-md);
    background-color: var(--section-light-bg);
    border-left: 3px solid var(--sky-blue);
    margin-bottom: var(--space-md);
  }

  .prequal-summary strong {
    color: var(--sky-blue);
  }

  .prequal-edit-link {
    background: none;
    border: none;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--sky-blue);
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
  }

  .prequal-edit-link:hover {
    color: var(--heading-color);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--sky-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    font-family: var(--font-body);
    font-size: var(--text-base);
    padding: var(--space-sm) var(--space-md);
    background-color: var(--section-light-bg);
    border: 2px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--heading-color);
    transition: all var(--transition-base);
    width: 100%;
    max-width: 100%;
    min-height: 48px;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--sky-blue);
    box-shadow: 0 0 0 3px rgba(200, 240, 74, 0.2);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--placeholder-color);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 600px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Contact Info Section */
  .contact-info {
    background-color: var(--color-bg-base);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 700px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .info-card {
    background-color: var(--color-bg-raised);
    padding: var(--space-xl);
    border-radius: var(--card-radius);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .info-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .info-link {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-primary);
    margin-bottom: var(--space-xs);
    transition: color var(--transition-fast);
  }

  .info-link:hover {
    color: var(--color-accent);
  }

  .info-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: var(--space-sm) 0 0;
  }
</style>
