---
/**
 * BrandIcon - Inline SVG icons from the Inform Growth brand system
 *
 * Usage:
 *   <BrandIcon name="deep-scan" size={24} />
 *   <BrandIcon name="compounding" size={32} class="my-icon" />
 */

interface Props {
  name: 'deep-scan' | 'data-stack' | 'integration' | 'pipeline' | 'compounding' | 'speed' | 'security' | 'attribution';
  size?: number;
  class?: string;
}

const { name, size = 24, class: className } = Astro.props;

// Icon definitions - inline SVG content for each icon
const icons = {
  'deep-scan': `
    <circle cx="10.5" cy="10.5" r="7" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="7" y1="8.5" x2="14.5" y2="8.5" stroke="var(--color-text-secondary)" stroke-width="1.2" stroke-opacity="0.45"/>
    <line x1="6" y1="10.5" x2="15" y2="10.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <line x1="7" y1="12.5" x2="14.5" y2="12.5" stroke="var(--color-text-secondary)" stroke-width="1.2" stroke-opacity="0.45"/>
  `,
  'data-stack': `
    <rect x="3" y="3" width="17" height="5" rx="1.5" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <rect x="3" y="10" width="17" height="5" rx="1.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <rect x="3" y="17" width="17" height="5" rx="1.5" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <circle cx="21" cy="5.5" r="1" fill="var(--color-text-secondary)"/>
    <circle cx="21" cy="12.5" r="1" fill="var(--color-accent)"/>
    <circle cx="21" cy="19.5" r="1" fill="var(--color-text-secondary)"/>
  `,
  'integration': `
    <circle cx="12" cy="12" r="2.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <circle cx="3.5" cy="12" r="2" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <circle cx="18.5" cy="5" r="2" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <circle cx="18.5" cy="19" r="2" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="5.5" y1="12" x2="9.5" y2="12" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="17" y1="6.4" x2="14.1" y2="10" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="17" y1="17.6" x2="14.1" y2="14" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
  `,
  'pipeline': `
    <path d="M4,3 L20,3 L14,12 L14,19 L10,19 L10,12 Z" stroke="var(--color-text-secondary)" stroke-width="1.5" stroke-linejoin="round"/>
    <circle cx="8" cy="6.5" r="1" fill="var(--color-text-secondary)"/>
    <circle cx="12" cy="6.5" r="1" fill="var(--color-text-secondary)"/>
    <circle cx="16" cy="6.5" r="1" fill="var(--color-text-secondary)"/>
    <line x1="12" y1="19" x2="12" y2="21.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <polyline points="10,20.2 12,22.5 14,20.2" stroke="var(--color-accent)" stroke-width="1.5" fill="none"/>
  `,
  'compounding': `
    <rect x="2" y="16" width="5" height="6" rx="0.5" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <rect x="9" y="11" width="5" height="11" rx="0.5" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <rect x="16" y="6" width="5" height="16" rx="0.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <line x1="18.5" y1="6" x2="18.5" y2="3.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <polyline points="17,4.8 18.5,2.5 20,4.8" stroke="var(--color-accent)" stroke-width="1.5" fill="none"/>
  `,
  'speed': `
    <line x1="3" y1="9" x2="7.5" y2="9" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="2" y1="12" x2="6.5" y2="12" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="3" y1="15" x2="7.5" y2="15" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="8.5" y1="12" x2="18" y2="12" stroke="var(--color-accent)" stroke-width="1.5"/>
    <polyline points="14,8.5 19,12 14,15.5" stroke="var(--color-accent)" stroke-width="1.5" fill="none"/>
  `,
  'security': `
    <path d="M12,2 L20,6 L20,15 Q20,20 12,22 Q4,20 4,15 L4,6 Z" stroke="var(--color-text-secondary)" stroke-width="1.5" stroke-linejoin="round"/>
    <polyline points="8.5,12 11,14.5 16,9" stroke="var(--color-accent)" stroke-width="1.8" fill="none"/>
  `,
  'attribution': `
    <circle cx="4" cy="5" r="2" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <circle cx="12" cy="5" r="2" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <circle cx="20" cy="5" r="2" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <circle cx="12" cy="20" r="2.5" stroke="var(--color-accent)" stroke-width="1.5"/>
    <line x1="5" y1="7" x2="10.5" y2="17.8" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="12" y1="7" x2="12" y2="17.5" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
    <line x1="19" y1="7" x2="13.5" y2="17.8" stroke="var(--color-text-secondary)" stroke-width="1.5"/>
  `
};

const iconContent = icons[name];
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['brand-icon', className]}
  aria-hidden="true"
  set:html={iconContent}
/>

<style>
  .brand-icon {
    display: inline-block;
    flex-shrink: 0;
  }
</style>
