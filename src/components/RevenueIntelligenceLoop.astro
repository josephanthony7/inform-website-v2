---
// RevenueIntelligenceLoop.astro
// The Revenue Intelligence Loop - animated figure-8 diagram
// Shows how Inform Growth connects the full outbound cycle with
// an intelligence return loop. Powered by simple-icons (jsdelivr CDN).
// PLACEMENT: After the proof strip / client logo section, before Deep-Scan.
---

<section class="loop-section">
  <div class="container">

    <div class="loop-header">
      <p class="loop-eyebrow">The system behind the results</p>
      <h2 class="loop-title">The Revenue Intelligence Loop</h2>
      <p class="loop-sub">Every signal, call, and email feeds back into a shared foundation. Only possible with Inform Growth.</p>
    </div>

    <div class="loop-diagram-wrap">
      <svg
        width="100%"
        viewBox="0 0 800 510"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Revenue Intelligence Loop diagram showing how Inform Growth connects signals, identification, enrichment, content generation, engagement, and compounding intelligence"
      >
        <defs>
          <pattern id="loop-dg" width="26" height="26" patternUnits="userSpaceOnUse">
            <circle cx=".5" cy=".5" r=".5" fill="rgba(45,80,22,.1)"/>
          </pattern>
          <path id="loop-f8" d="M400,244 C400,136 158,136 158,244 C158,352 400,352 400,244 C400,136 642,136 642,244 C642,352 400,352 400,244"/>
          <path id="loop-ret" d="M518,330 Q400,436 282,330"/>
          <radialGradient id="loop-hubglow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#2D5016" stop-opacity="0.15"/>
            <stop offset="100%" stop-color="#2D5016" stop-opacity="0"/>
          </radialGradient>
        </defs>

        <!-- Background -->
        <rect width="800" height="510" fill="#F7F7F5"/>
        <rect width="800" height="510" fill="url(#loop-dg)"/>

        <!-- Ambient stars -->
        <circle cx="60" cy="60" r="1" fill="rgba(45,80,22,.25)"/>
        <circle cx="738" cy="66" r="1.1" fill="rgba(45,80,22,.2)"/>
        <circle cx="400" cy="44" r=".9" fill="rgba(45,80,22,.25)"/>
        <circle cx="72" cy="400" r=".8" fill="rgba(45,80,22,.15)"/>
        <circle cx="724" cy="398" r=".9" fill="rgba(45,80,22,.15)"/>

        <!-- Figure-8 glow -->
        <path d="M400,244 C400,136 158,136 158,244 C158,352 400,352 400,244" stroke="rgba(45,80,22,.08)" stroke-width="20" fill="none"/>
        <path d="M400,244 C400,136 642,136 642,244 C642,352 400,352 400,244" stroke="rgba(45,80,22,.08)" stroke-width="20" fill="none"/>

        <!-- Figure-8 animated paths -->
        <path d="M400,244 C400,136 158,136 158,244 C158,352 400,352 400,244" stroke="rgba(45,80,22,.35)" stroke-width="1.25" stroke-dasharray="7 5" fill="none">
          <animate attributeName="stroke-dashoffset" from="0" to="-24" dur="0.8s" repeatCount="indefinite"/>
        </path>
        <path d="M400,244 C400,136 642,136 642,244 C642,352 400,352 400,244" stroke="rgba(45,80,22,.35)" stroke-width="1.25" stroke-dasharray="7 5" fill="none">
          <animate attributeName="stroke-dashoffset" from="0" to="-24" dur="0.8s" repeatCount="indefinite"/>
        </path>

        <!-- Return arc glow + path -->
        <path d="M518,330 Q400,436 282,330" stroke="rgba(45,80,22,.1)" stroke-width="14" fill="none"/>
        <path d="M518,330 Q400,436 282,330" stroke="rgba(45,80,22,.5)" stroke-width="1.25" stroke-dasharray="6 5" fill="none">
          <animate attributeName="stroke-dashoffset" from="22" to="0" dur="0.8s" repeatCount="indefinite"/>
        </path>

        <!-- Return arc label -->
        <text x="400" y="456" text-anchor="middle"
              font-family="'Inter',system-ui,sans-serif" font-size="10.5"
              fill="rgba(45,80,22,.5)" letter-spacing=".03em">
          Every call · email · signal returns. Compounding with every deal.
        </text>

        <!-- ── N1: SIGNALS (278,158) ──────────────────── -->
        <line x1="263" y1="147" x2="208" y2="116" stroke="rgba(45,80,22,.2)" stroke-width=".75" stroke-dasharray="3 3"/>
        <circle cx="278" cy="158" r="22" stroke="rgba(45,80,22,.1)" stroke-width="1" fill="none"/>
        <circle cx="278" cy="158" r="13" stroke="rgba(45,80,22,.3)" stroke-width="1" fill="none"/>
        <circle cx="278" cy="158" r="5.5" fill="#2D5016">
          <animate attributeName="r" values="5;6.5;5" dur="3s" repeatCount="indefinite" begin="0s"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="3s" repeatCount="indefinite" begin="0s"/>
        </circle>
        <text x="252" y="86" text-anchor="end" font-family="'Inter',system-ui,sans-serif" font-size="15" font-weight="700" fill="rgba(26,26,24,.88)">Signals</text>
        <!-- Apollo chip -->
        <g transform="translate(158,94)">
          <rect width="28" height="28" rx="6" fill="#000"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/apollo.svg" x="5" y="5" width="18" height="18" style="filter:brightness(0) invert(1) sepia(1) saturate(4) hue-rotate(20deg)"/>
          <rect width="28" height="28" rx="6" fill="none" stroke="rgba(255,200,40,.4)" stroke-width=".75"/>
        </g>
        <!-- Clay chip -->
        <g transform="translate(192,94)">
          <rect width="28" height="28" rx="6" fill="#FFFFFF" stroke="#E5E5E0" stroke-width="1"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/clay.svg" x="4" y="4" width="20" height="20" style="filter:brightness(0)"/>
          <rect width="28" height="28" rx="6" fill="none" stroke="rgba(80,160,220,.35)" stroke-width=".75"/>
        </g>
        <!-- LinkedIn chip -->
        <g transform="translate(222,94)">
          <rect width="28" height="28" rx="6" fill="#0A66C2"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/linkedin.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>

        <!-- ── N2: IDENTIFY (158,244) ──────────────────── -->
        <line x1="135" y1="242" x2="130" y2="242" stroke="rgba(45,80,22,.2)" stroke-width=".75" stroke-dasharray="3 3"/>
        <circle cx="158" cy="244" r="22" stroke="rgba(45,80,22,.1)" stroke-width="1" fill="none"/>
        <circle cx="158" cy="244" r="13" stroke="rgba(45,80,22,.3)" stroke-width="1" fill="none"/>
        <circle cx="158" cy="244" r="5.5" fill="#2D5016">
          <animate attributeName="r" values="5;6.5;5" dur="3s" repeatCount="indefinite" begin="1s"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="3s" repeatCount="indefinite" begin="1s"/>
        </circle>
        <text x="130" y="220" text-anchor="end" font-family="'Inter',system-ui,sans-serif" font-size="15" font-weight="700" fill="rgba(26,26,24,.88)">Identify</text>
        <!-- HubSpot chip -->
        <g transform="translate(100,228)">
          <rect width="28" height="28" rx="6" fill="#E8613D"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/hubspot.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- Attio chip -->
        <g transform="translate(100,260)">
          <rect width="28" height="28" rx="6" fill="#FFFFFF" stroke="#E5E5E0" stroke-width="1"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/attio.svg" x="5" y="5" width="18" height="18" style="filter:brightness(0)"/>
        </g>

        <!-- ── N3: ENRICH (278,330) ──────────────────── -->
        <line x1="263" y1="318" x2="208" y2="316" stroke="rgba(45,80,22,.2)" stroke-width=".75" stroke-dasharray="3 3"/>
        <circle cx="278" cy="330" r="22" stroke="rgba(45,80,22,.1)" stroke-width="1" fill="none"/>
        <circle cx="278" cy="330" r="13" stroke="rgba(45,80,22,.3)" stroke-width="1" fill="none"/>
        <circle cx="278" cy="330" r="5.5" fill="#2D5016">
          <animate attributeName="r" values="5;6.5;5" dur="3s" repeatCount="indefinite" begin="2s"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="3s" repeatCount="indefinite" begin="2s"/>
        </circle>
        <text x="252" y="304" text-anchor="end" font-family="'Inter',system-ui,sans-serif" font-size="15" font-weight="700" fill="rgba(26,26,24,.88)">Enrich</text>
        <!-- Apollo chip -->
        <g transform="translate(190,312)">
          <rect width="28" height="28" rx="6" fill="#000"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/apollo.svg" x="5" y="5" width="18" height="18" style="filter:brightness(0) invert(1) sepia(1) saturate(4) hue-rotate(20deg)"/>
          <rect width="28" height="28" rx="6" fill="none" stroke="rgba(255,200,40,.4)" stroke-width=".75"/>
        </g>
        <!-- Clay chip -->
        <g transform="translate(222,312)">
          <rect width="28" height="28" rx="6" fill="#FFFFFF" stroke="#E5E5E0" stroke-width="1"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/clay.svg" x="4" y="4" width="20" height="20" style="filter:brightness(0)"/>
          <rect width="28" height="28" rx="6" fill="none" stroke="rgba(80,160,220,.35)" stroke-width=".75"/>
        </g>
        <!-- BigQuery chip -->
        <g transform="translate(190,344)">
          <rect width="28" height="28" rx="6" fill="#4285F4"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/googlebigquery.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- GA4 chip -->
        <g transform="translate(222,344)">
          <rect width="28" height="28" rx="6" fill="#E37400"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/googleanalytics.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>

        <!-- ══════════════════════════════════════════════
             INFORM GROWTH HUB - Hero element
             ══════════════════════════════════════════════ -->

        <!-- Outermost ambient glow (breathing) -->
        <circle cx="400" cy="244" r="88" fill="url(#loop-hubglow)">
          <animate attributeName="r" values="84;92;84" dur="5s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="5s" repeatCount="indefinite"/>
        </circle>

        <!-- Outer rotating emerald ring -->
        <circle cx="400" cy="244" r="70" stroke="rgba(45,80,22,.45)" stroke-width="1.5" stroke-dasharray="5 3.5" fill="none">
          <animateTransform attributeName="transform" type="rotate" from="0 400 244" to="360 400 244" dur="20s" repeatCount="indefinite"/>
        </circle>

        <!-- Counter-rotating sky-blue ring -->
        <circle cx="400" cy="244" r="61" stroke="rgba(45,80,22,.28)" stroke-width="1" stroke-dasharray="3 7" fill="none">
          <animateTransform attributeName="transform" type="rotate" from="0 400 244" to="-360 400 244" dur="14s" repeatCount="indefinite"/>
        </circle>

        <!-- Static inner ring (pulsing) -->
        <circle cx="400" cy="244" r="53" stroke="rgba(45,80,22,.18)" stroke-width=".75" fill="none">
          <animate attributeName="stroke-opacity" values=".1;.28;.1" dur="3s" repeatCount="indefinite"/>
        </circle>

        <!-- Core light fill -->
        <circle cx="400" cy="244" r="46" fill="#FFFFFF"/>

        <!-- Core border - breathing glow -->
        <circle cx="400" cy="244" r="46" fill="none" stroke="#2D5016" stroke-width="2.5">
          <animate attributeName="stroke-opacity" values=".55;1;.55" dur="2.8s" repeatCount="indefinite"/>
          <animate attributeName="stroke-width" values="2;3;2" dur="2.8s" repeatCount="indefinite"/>
        </circle>

        <!-- Anthropic / Claude icon - centered upper portion -->
        <image
          href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/anthropic.svg"
          x="387" y="210" width="26" height="26"
          style="filter:brightness(0) saturate(0)"
        />

        <!-- INFORM GROWTH wordmark -->
        <text x="400" y="247" text-anchor="middle"
              font-family="'Inter',system-ui,sans-serif"
              font-size="9" font-weight="700"
              fill="rgba(26,26,24,.95)" letter-spacing=".08em">
          INFORM GROWTH
        </text>

        <!-- Enabling Claude tagline -->
        <text x="400" y="262" text-anchor="middle"
              font-family="'Inter',system-ui,sans-serif"
              font-size="7.5"
              fill="rgba(45,80,22,.9)" letter-spacing=".06em">
          Enabling Claude
        </text>

        <!-- ══════════════════════════════════════════════ -->

        <!-- ── N4: CONTENT (522,158) ──────────────────── -->
        <line x1="537" y1="147" x2="574" y2="116" stroke="rgba(45,80,22,.2)" stroke-width=".75" stroke-dasharray="3 3"/>
        <circle cx="522" cy="158" r="22" stroke="rgba(45,80,22,.1)" stroke-width="1" fill="none"/>
        <circle cx="522" cy="158" r="13" stroke="rgba(45,80,22,.35)" stroke-width="1" fill="none"/>
        <circle cx="522" cy="158" r="5.5" fill="#2D5016">
          <animate attributeName="r" values="5;6.5;5" dur="3s" repeatCount="indefinite" begin="0.5s"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="3s" repeatCount="indefinite" begin="0.5s"/>
        </circle>
        <text x="548" y="86" text-anchor="start" font-family="'Inter',system-ui,sans-serif" font-size="15" font-weight="700" fill="rgba(26,26,24,.88)">Content</text>
        <!-- Anthropic chip -->
        <g transform="translate(548,94)">
          <rect width="28" height="28" rx="6" fill="#CC785C"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/anthropic.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- Zapier chip -->
        <g transform="translate(580,94)">
          <rect width="28" height="28" rx="6" fill="#FF4A00"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/zapier.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- Make.com chip -->
        <g transform="translate(548,126)">
          <rect width="28" height="28" rx="6" fill="#6E1CCA"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/make.svg" x="6" y="6" width="16" height="16" style="filter:brightness(0) invert(1)"/>
        </g>

        <!-- ── N5: ENGAGE (642,244) ──────────────────── -->
        <line x1="666" y1="242" x2="668" y2="242" stroke="rgba(45,80,22,.2)" stroke-width=".75" stroke-dasharray="3 3"/>
        <circle cx="642" cy="244" r="22" stroke="rgba(45,80,22,.1)" stroke-width="1" fill="none"/>
        <circle cx="642" cy="244" r="13" stroke="rgba(45,80,22,.35)" stroke-width="1" fill="none"/>
        <circle cx="642" cy="244" r="5.5" fill="#2D5016">
          <animate attributeName="r" values="5;6.5;5" dur="3s" repeatCount="indefinite" begin="1.5s"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="3s" repeatCount="indefinite" begin="1.5s"/>
        </circle>
        <text x="670" y="220" text-anchor="start" font-family="'Inter',system-ui,sans-serif" font-size="15" font-weight="700" fill="rgba(26,26,24,.88)">Engage</text>
        <!-- Gong chip -->
        <g transform="translate(670,228)">
          <rect width="28" height="28" rx="6" fill="#111"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/gong.svg" x="5" y="5" width="18" height="18" style="filter:brightness(0) invert(1) sepia(1) saturate(3) hue-rotate(260deg)"/>
          <rect width="28" height="28" rx="6" fill="none" stroke="rgba(140,60,220,.5)" stroke-width=".75"/>
        </g>
        <!-- Salesloft chip -->
        <g transform="translate(702,228)">
          <rect width="28" height="28" rx="6" fill="#164FA5"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/salesloft.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- Granola chip -->
        <g transform="translate(734,228)">
          <rect width="28" height="28" rx="6" fill="#7FD47F"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/granola.svg" x="6" y="6" width="16" height="16" style="filter:brightness(0)"/>
          <rect width="28" height="28" rx="6" fill="none" stroke="rgba(0,100,0,.35)" stroke-width=".75"/>
        </g>

        <!-- ── N6: COMPOUNDS (522,330) ──────────────────── -->
        <line x1="537" y1="318" x2="578" y2="316" stroke="rgba(45,80,22,.25)" stroke-width=".75" stroke-dasharray="3 3"/>
        <circle cx="522" cy="330" r="22" stroke="rgba(45,80,22,.12)" stroke-width="1" fill="none"/>
        <circle cx="522" cy="330" r="13" stroke="rgba(45,80,22,.45)" stroke-width="1" fill="none"/>
        <circle cx="522" cy="330" r="5.5" fill="#2D5016">
          <animate attributeName="r" values="5;6.5;5" dur="3s" repeatCount="indefinite" begin="2.5s"/>
          <animate attributeName="opacity" values=".7;1;.7" dur="3s" repeatCount="indefinite" begin="2.5s"/>
        </circle>
        <text x="548" y="304" text-anchor="start" font-family="'Inter',system-ui,sans-serif" font-size="15" font-weight="700" fill="rgba(45,80,22,.85)">Compounds</text>
        <!-- HubSpot chip -->
        <g transform="translate(548,312)">
          <rect width="28" height="28" rx="6" fill="#E8613D"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/hubspot.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- Salesforce chip -->
        <g transform="translate(580,312)">
          <rect width="28" height="28" rx="6" fill="#0070D2"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/salesforce.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- Power BI chip -->
        <g transform="translate(548,344)">
          <rect width="28" height="28" rx="6" fill="#1E2432" stroke="rgba(242,200,17,.4)" stroke-width=".75"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/microsoftpowerbi.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>
        <!-- dbt chip -->
        <g transform="translate(580,344)">
          <rect width="28" height="28" rx="6" fill="#FF694B"/>
          <image href="https://cdn.jsdelivr.net/npm/simple-icons@13/icons/dbt.svg" x="7" y="7" width="14" height="14" style="filter:brightness(0) invert(1)"/>
        </g>

        <!-- ── Particles on figure-8 ──────────────────── -->
        <circle r="3.5" fill="#2D5016" opacity=".92">
          <animateMotion dur="9s" repeatCount="indefinite" begin="0s" calcMode="linear"><mpath href="#loop-f8"/></animateMotion>
        </circle>
        <circle r="2.5" fill="#2D5016" opacity=".7">
          <animateMotion dur="9s" repeatCount="indefinite" begin="2.25s" calcMode="linear"><mpath href="#loop-f8"/></animateMotion>
        </circle>
        <circle r="3" fill="#2D5016" opacity=".82">
          <animateMotion dur="9s" repeatCount="indefinite" begin="4.5s" calcMode="linear"><mpath href="#loop-f8"/></animateMotion>
        </circle>
        <circle r="2" fill="#2D5016" opacity=".6">
          <animateMotion dur="9s" repeatCount="indefinite" begin="6.75s" calcMode="linear"><mpath href="#loop-f8"/></animateMotion>
        </circle>

        <!-- ── Particles on return arc (emerald) ──────── -->
        <circle r="3.5" fill="#2D5016" opacity=".88">
          <animateMotion dur="4.5s" repeatCount="indefinite" begin="0s" calcMode="linear"><mpath href="#loop-ret"/></animateMotion>
        </circle>
        <circle r="2.5" fill="#2D5016" opacity=".65">
          <animateMotion dur="4.5s" repeatCount="indefinite" begin="2.25s" calcMode="linear"><mpath href="#loop-ret"/></animateMotion>
        </circle>

        <!-- Bottom caption -->
        <text x="400" y="490" text-anchor="middle"
              font-family="'Inter',system-ui,sans-serif" font-size="9.5"
              fill="rgba(45,80,22,.3)" letter-spacing=".04em">
          Built on clean data · Governed AI · Shared context
        </text>
      </svg>
    </div>

  </div>
</section>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .loop-section {
    background-color: var(--off-white);
    padding: var(--space-section-mobile) 0;
  }

  @media (min-width: 768px) {
    .loop-section {
      padding: var(--space-section) 0;
    }
  }

  /* ── Header ──────────────────────────────────────────── */
  .loop-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-2xl);
  }

  .loop-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--sky-blue);
    margin-bottom: var(--space-3);
  }

  .loop-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .loop-sub {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--slate);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Diagram wrapper ─────────────────────────────────── */
  .loop-diagram-wrap {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    /* Subtle box-shadow to lift it off the light bg */
    box-shadow: 0 8px 32px rgba(45, 80, 22, 0.08),
                0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .loop-diagram-wrap svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Accessibility ───────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .loop-diagram-wrap svg animate,
    .loop-diagram-wrap svg animateTransform,
    .loop-diagram-wrap svg animateMotion {
      animation-play-state: paused;
    }
  }
</style>
